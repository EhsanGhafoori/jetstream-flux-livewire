{
    "name": "ehsanghafoori/jetstream-flux-livewire",
    "description": "Personal Jetstream fork: Livewire 4, Tailwind 4, and Flux UI — Livewire stack only.",
    "keywords": ["laravel", "jetstream", "livewire", "flux", "tailwind", "auth"],
    "license": "MIT",
    "homepage": "https://github.com/EhsanGhafoori/jetstream-flux-livewire",
    "support": {
        "issues": "https://github.com/EhsanGhafoori/jetstream-flux-livewire/issues",
        "source": "https://github.com/EhsanGhafoori/jetstream-flux-livewire"
    },
    "authors": [
        {
            "name": "Ehsan Ghafoori",
            "email": "ehgh1996@gmail.com",
            "homepage": "https://github.com/EhsanGhafoori",
            "role": "Maintainer"
        }
    ],
    "require": {
        "php": "^8.2.0",
        "ext-json": "*",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "laravel/fortify": "^1.20",
        "mobiledetect/mobiledetectlib": "^4.8.08",
        "symfony/console": "^7.0|^8.0"
    },
    "require-dev": {
        "laravel/sanctum": "^4.0",
        "livewire/livewire": "^4.0",
        "livewire/flux": "^2.0",
        "mockery/mockery": "^1.0",
        "orchestra/testbench": "^9.15|^10.8|^11.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Laravel\\Jetstream\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Laravel\\Jetstream\\Tests\\": "tests/",
            "App\\": "stubs/app/",
            "Database\\Factories\\": "database/factories/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Laravel\\Jetstream\\JetstreamServiceProvider"
            ]
        }
    },
    "config": {
        "audit": {
            "block-insecure": false
        },
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
